  "components" : {
    "schemas" : {
      "Message" : {
        "required" : [ "message" ],
        "type" : "object",
        "properties" : {
          "message" : {
            "type" : "string"
          }
        }
      },
      "LoginInfo" : {
        "type" : "object",
        "properties" : {
          "username" : {
            "type" : "string"
          },
          "password" : {
            "type" : "string"
          },
          "email" : {
            "type" : "string"
          },
          "friends" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/LoginInfo"
            }
          }
        }
      },
      "LobbyCode" : {
        "required" : [ "code" ],
        "type" : "object",
        "properties" : {
          "code" : {
            "type" : "string"
          }
        }
      },
      "SingleVote" : {
        "required" : [ "username", "uservote" ],
        "type" : "object",
        "properties" : {
          "username" : {
            "type" : "string"
          },
          "uservote" : {
            "type" : "boolean"
          }
        }
      },
      "AssassinGuess" : {
        "required" : [ "guess" ],
        "type" : "object",
        "properties" : {
          "guess" : {
            "type" : "string"
          }
        }
      },
      "Settings" : {
        "required" : [ "arnold", "assassin", "mordred", "morgana", "oberon", "percival" ],
        "type" : "object",
        "properties" : {
          "assassin" : {
            "type" : "boolean"
          },
          "mordred" : {
            "type" : "boolean"
          },
          "morgana" : {
            "type" : "boolean"
          },
          "oberon" : {
            "type" : "boolean"
          },
          "percival" : {
            "type" : "boolean"
          },
          "arnold" : {
            "type" : "boolean"
          }
        }
      },
      "Info" : {
        "required" : [ "assassinHasGuessed", "currentAdventure", "currentRound", "failCounter", "isAdventure", "playerSelectNum", "playersName", "scores", "selectedForAdventure", "started", "winner" ],
        "type" : "object",
        "properties" : {
          "started" : {
            "type" : "boolean"
          },
          "winner" : {
            "type" : "string",
            "enum" : [ "NOT_DECIDED", "EVIL", "GOOD" ]
          },
          "scores" : {
            "type" : "array",
            "items" : {
              "type" : "string",
              "enum" : [ "EVIL", "GOOD", "UNDECIDED" ]
            }
          },
          "currentRound" : {
            "type" : "integer",
            "format" : "int32"
          },
          "isAdventure" : {
            "type" : "boolean"
          },
          "currentAdventure" : {
            "type" : "integer",
            "format" : "int32"
          },
          "king" : {
            "type" : "string"
          },
          "failCounter" : {
            "type" : "integer",
            "format" : "int32"
          },
          "selectedForAdventure" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          },
          "playersName" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          },
          "assassinHasGuessed" : {
            "type" : "boolean"
          },
          "playerSelectNum" : {
            "type" : "integer",
            "format" : "int32"
          }
        }
      },
      "CharacterInfo" : {
        "required" : [ "name", "sees" ],
        "type" : "object",
        "properties" : {
          "name" : {
            "type" : "string",
            "enum" : [ "PERCIVAL", "MERLIN", "SERVANT_OF_ARTHUR", "ARNOLD", "ASSASSIN", "MORGANA", "MORDRED", "OBERON", "MINION_OF_MORDRED" ]
          },
          "sees" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          }
        }
      }
    }
  }
}
