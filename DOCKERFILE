FROM gradle:7.6-jdk17 as builder
USER root
WORKDIR /builder
ADD . /builder
# -x test: tests run in CI; keeps the on-device (Raspberry Pi) image build fast
RUN gradle build --stacktrace -x test

FROM eclipse-temurin:17-jre
WORKDIR /app
EXPOSE 8080
COPY --from=builder /builder/build/libs/*.jar app.jar
CMD ["java", "-jar", "app.jar"]
